# Repo-local environment variables (not committed).
# Copy this file to `.env` and fill in secrets as needed.
# The worktree Compose launcher reads application credentials from this file.
# Stable ports and generated local credentials are written to ignored `.dev.env`.
#
# GitHub fine-grained PAT scoped to this repo (used by Codex for `gh` and HTTPS `git push`).
# Required scopes typically include: Contents (read/write), Pull requests (read/write), Issues (read).
# Prefer the repo-specific name; GH_AUTH_TOKEN/GH_TOKEN/GITHUB_TOKEN are also accepted.
CALIBRATE_GH_PAT=
GITHUB_TOKEN=

# Food data providers (used by the worktree development stack).
# Defaults to FatSecret when both FatSecret credentials are set, then USDA.
# Local development uses USDA's public DEMO_KEY when no provider credentials are available.
# Set explicitly to override, including openfoodfacts when you want to test OFF.
FOOD_DATA_PROVIDER=
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

USDA_API_KEY=

# Optional complete port override set. Set all three together.
# CALIBRATE_DEV_BACKEND_PORT=20000
# CALIBRATE_DEV_POSTGRES_PORT=30000
# CALIBRATE_DEV_WEB_PORT=40000

# Web push (VAPID) configuration used by backend push endpoints.
# The development launcher auto-generates these in `.dev.env` when missing.
# Set them here to override generated values.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Native Android push crosses the Expo service boundary and is disabled unless explicitly enabled.
# Supported values: disabled, expo.
NATIVE_PUSH_MODE=disabled

# Public Expo project identity used by native push and Expo OTA release builds.
# EXPO_PUBLIC_EAS_PROJECT_ID=<expo-project-uuid>
# EXPO_UPDATES_CHANNEL=internal

# Reminder scheduling (local hour 0-23, and scan interval in minutes).
REMINDER_SEND_LOCAL_HOUR=9
REMINDER_JOB_INTERVAL_MINUTES=15

# Optional self-host diagnostics. Disabled by default and never sends data to an external service.
# When enabled, the backend writes one redacted JSON completion event per request to stdout.
# Set a random 32+ character token to additionally enable GET /internal/diagnostics/metrics.
# CALIBRATE_DIAGNOSTICS_ENABLED=false
# CALIBRATE_DIAGNOSTICS_METRICS_TOKEN=

# Deployed Wear pairing requires HTTPS. Only set this for an intentionally cleartext LAN/loopback
# self-host; pairing credentials and health traffic can otherwise be intercepted.
# ALLOW_INSECURE_WEAR_PAIRING=false
