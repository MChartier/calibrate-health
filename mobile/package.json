{
  "name": "mobile",
  "version": "0.2.2",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "build:web": "node ../scripts/expo-web-build.mjs",
    "preview:web": "node ../scripts/expo-web-preview.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@calibrate/api-client": "file:../packages/api-client",
    "@calibrate/shared": "file:../shared",
    "@calibrate/wear-pairing": "file:modules/wear-pairing",
    "@expo/metro-runtime": "~57.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@tanstack/react-query": "^5.100.10",
    "abort-controller": "^3.0.0",
    "expo": "~57.0.7",
    "expo-application": "~57.0.2",
    "expo-build-properties": "~57.0.6",
    "expo-camera": "~57.0.3",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image-picker": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.6",
    "expo-sqlite": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-health-connect": "3.5.3",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "regenerator-runtime": "^0.13.11",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@react-native/jest-preset": "0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~57.0.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "^29.7.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "moduleNameMapper": {
      "^expo/virtual/env$": "<rootDir>/test/expoVirtualEnv.js",
      "^uuid$": "<rootDir>/../node_modules/uuid/dist/cjs/index.js"
    },
    "testMatch": [
      "**/*.test.ts",
      "**/*.test.tsx"
    ]
  }
