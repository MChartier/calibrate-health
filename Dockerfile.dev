FROM node:22.14.0-bookworm

WORKDIR /workspace
RUN chown node:node /workspace
USER node

# Dependency layers follow manifests, while Compose Watch supplies live source updates.
COPY --chown=node:node package.json package-lock.json ./
COPY --chown=node:node mobile/package.json ./mobile/package.json
COPY --chown=node:node mobile/modules/wear-pairing/package.json ./mobile/modules/wear-pairing/package.json
COPY --chown=node:node packages/api-client/package.json ./packages/api-client/package.json
COPY --chown=node:node shared/package.json ./shared/package.json
RUN npm ci --no-audit --fund=false

COPY --chown=node:node backend/package.json backend/package-lock.json ./backend/
RUN npm --prefix backend ci --no-audit --fund=false

COPY --chown=node:node . .
RUN npm run prisma:generate

ENV BROWSER=none
ENV EXPO_UNSTABLE_HEADLESS=1

CMD ["npm", "--help"]
