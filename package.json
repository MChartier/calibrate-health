{
  "name": "cal-io",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "workspaces": [
    "mobile",
    "shared",
    "packages/*"
  ],
  "scripts": {
    "dev": "VITE_ENABLE_SW_DEV=1 node scripts/dev.mjs",
    "dev:test": "AUTO_LOGIN_TEST_USER=true VITE_ENABLE_SW_DEV=1 node scripts/dev.mjs",
    "dev:reset-test-user-onboarding": "node scripts/reset-test-user-onboarding.mjs",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:storybook": "node scripts/storybook-dev.mjs",
    "preview": "node scripts/preview.mjs",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:migrate:dev": "node scripts/dev-env.mjs db:migrate",
    "db:migrate:create": "npm --prefix backend run db:migrate:dev",
    "db:reset": "npm --prefix backend run db:reset",
    "db:reset:dev": "node scripts/dev-env.mjs db:reset",
    "db:seed": "npm --prefix backend run db:seed",
    "db:studio": "npm --prefix backend run db:studio",
    "setup": "node scripts/dev-env.mjs setup",
    "setup:deps": "node scripts/dev-env.mjs deps",
    "worktree:new": "node scripts/worktree.mjs",
    "worktree:code": "node scripts/worktree-code.mjs",
    "worktree:reset": "node scripts/worktree-reset.mjs",
    "devcontainer:up": "node scripts/devcontainer-worktree.mjs up",
    "devcontainer:up:new": "node scripts/devcontainer-worktree.mjs up --remove-existing-container",
    "devcontainer:exec": "node scripts/devcontainer-worktree.mjs exec",
    "devcontainer:shell": "node scripts/devcontainer-worktree.mjs shell",
    "devcontainer:shell:new": "node scripts/devcontainer-worktree.mjs shell --remove-existing-container",
    "codex:devcontainer:start": "node scripts/codex-worktree-env.mjs devcontainer:start",
    "codex:devcontainer:recreate": "node scripts/codex-worktree-env.mjs devcontainer:recreate",
    "codex:devcontainer:down": "node scripts/codex-worktree-env.mjs down",
    "codex:setup-app": "node scripts/codex-worktree-env.mjs setup-app",
    "codex:db:migrate": "node scripts/codex-worktree-env.mjs db:migrate",
    "codex:db:reset": "node scripts/codex-worktree-env.mjs db:reset",
    "codex:shell": "node scripts/codex-worktree-env.mjs shell",
    "codex:test": "node scripts/codex-worktree-env.mjs test",
    "codex:test:coverage": "node scripts/codex-worktree-env.mjs test:coverage",
    "codex:lint": "node scripts/codex-worktree-env.mjs lint",
    "codex:build": "node scripts/codex-worktree-env.mjs build",
    "codex:storybook": "node scripts/codex-worktree-env.mjs storybook",
    "codex:ci": "node scripts/codex-worktree-env.mjs ci",
    "codex:dev": "node scripts/codex-worktree-env.mjs dev",
    "codex:dev:test": "node scripts/codex-worktree-env.mjs dev",
    "codex:down": "node scripts/codex-worktree-env.mjs down",
    "ci:local": "node scripts/dev-env.mjs ci",
    "build": "npm --prefix frontend run build",
    "build:mobile": "npm --prefix mobile run typecheck",
    "build:native:release": "node scripts/native-release-build.mjs",
    "api:generate": "openapi-typescript docs/openapi/v1.yaml -o packages/api-client/src/generated/v1.ts",
    "api:contract:check": "npm run api:generate && git diff --exit-code -- packages/api-client/src/generated/v1.ts",
    "release:check": "node scripts/release-config.mjs check",
    "release:metadata": "node scripts/release-config.mjs metadata",
    "test:release": "node --test scripts/release-config.test.mjs",
    "test:native-release": "node --test scripts/native-release-build.test.mjs",
    "test:build-budget": "node --test scripts/frontend-build-budget.test.mjs",
    "build:storybook": "npm --prefix frontend run storybook:build",
    "lint": "npm --prefix frontend run lint",
    "lint:mobile": "npm --prefix mobile run typecheck",
    "test": "npm run test:backend && npm run test:frontend && npm run test:mobile",
    "test:backend": "npm --prefix backend test",
    "test:frontend": "npm --prefix frontend test",
    "test:mobile": "npm --prefix mobile test",
    "test:android:e2e": "node scripts/android-e2e.mjs",
    "test:wear:emulator": "node scripts/wear-emulator-smoke.mjs",
    "test:wear:emulator:unit": "node --test scripts/wear-emulator-smoke.test.mjs",
    "test:db:upgrade": "node scripts/postgres-populated-upgrade-smoke.mjs",
    "test:db:upgrade:unit": "node --test scripts/postgres-populated-upgrade-smoke.test.mjs",
    "test:deploy": "node --test deploy/test/*.test.mjs",
    "deploy:config:check": "node deploy/scripts/validate-compose.mjs",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "npm --prefix backend run test:coverage",
    "test:coverage:frontend": "npm --prefix frontend run test:coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@devcontainers/cli": "^0.86.0",
    "@types/node": "^20.0.0",
    "expo-font": "~14.0.12",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.0.0"
  }
}
