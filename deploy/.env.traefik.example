# App image published by CI to GHCR.
APP_IMAGE=ghcr.io/mchartier/calibratehealth:master

# Public host routed by Traefik.
APP_HOST=calibratehealth.example.com

# Required app secret (generate with: openssl rand -base64 32)
SESSION_SECRET=replace-with-random

# Postgres settings for the in-stack database.
POSTGRES_DB=calibratehealth
POSTGRES_USER=calibratehealth
POSTGRES_PASSWORD=replace-with-strong-password

# Traefik shared network + cert resolver names from your Traefik deployment.
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# Optional push notification settings.
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=

# Optional food provider configuration.
FOOD_DATA_PROVIDER=fatsecret
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
USDA_API_KEY=
