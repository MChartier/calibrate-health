# Application image and public hostname.
APP_IMAGE=ghcr.io/mchartier/calibratehealth:master
APP_HOST=calibratehealth.example.com
SESSION_SECRET=replace-with-at-least-32-random-bytes

# External Postgres mode. Omit DATABASE_URL when using docker-compose.postgres.yml.
DATABASE_URL=postgresql://calibrate:PASSWORD@postgres.example.com:5432/calibrate?schema=public&sslmode=verify-full

# In-stack Postgres mode.
POSTGRES_DB=calibratehealth
POSTGRES_USER=calibratehealth
POSTGRES_PASSWORD=replace-with-strong-unique-password
POSTGRES_SCHEMA=public

# Caddy or Traefik integration.
CADDY_EMAIL=operator@example.com
CADDYFILE=./Caddyfile.prod
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# Encrypted automated backups. Keep the age private identity offline and off this host when possible.
BACKUP_AGE_RECIPIENT=age1replace-with-your-public-recipient
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

# For external Postgres backups, set these explicitly and choose the provider-required SSL mode.
BACKUP_DB_HOST=postgres.example.com
BACKUP_DB_PORT=5432
BACKUP_DB_NAME=calibrate
BACKUP_DB_USER=calibrate_backup
BACKUP_DB_PASSWORD=replace-with-backup-user-password
BACKUP_DB_SSLMODE=verify-full

# Optional self-host-safe JSON logs and aggregate metrics. Use a random 32+ character token.
CALIBRATE_DIAGNOSTICS_ENABLED=false
CALIBRATE_DIAGNOSTICS_METRICS_TOKEN=

# Optional notification providers. Native push is disabled unless explicitly opted into Expo.
NATIVE_PUSH_MODE=disabled
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=
FOOD_DATA_PROVIDER=fatsecret
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
USDA_API_KEY=
